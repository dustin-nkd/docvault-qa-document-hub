{
  "manifest_version": 3,
  "name": "DocVault - QA Document Hub",
  "version": "1.0.0",
  "description": "Quản lý tài liệu QA - Lưu trữ offline trên trình duyệt. Hỗ trợ Runbook, Onboarding, Test Cases, Knowledge Base.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "identity"
  ],
  "oauth2": {
    "client_id": "821273695892-0n81gju50nenhne1ohmkedmvv2ik09qv.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.appdata"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
