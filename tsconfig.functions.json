{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "lib": [
      "ES2023"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023"
  },
  "include": [
    "worker-configuration.d.ts",
    "workers/identity-burst-configuration.d.ts",
    "workers/**/*.ts",
    "functions/**/*.ts",
    "functions/**/*.mjs"
  ]
}
