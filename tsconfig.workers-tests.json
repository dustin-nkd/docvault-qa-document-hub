{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "lib": [
      "ES2023"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "types": [
      "@cloudflare/vitest-pool-workers/types",
      "node"
    ]
  },
  "include": [
    "worker-configuration.d.ts",
    "workers/identity-burst-configuration.d.ts",
    "workers/**/*.ts",
    "functions/_lib/**/*.mjs",
    "tests/helpers/runtime-dependencies.mjs",
    "tests/cloudflare/**/*.ts",
    "vitest.config.mts"
  ]
}
